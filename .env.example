# Copy this file to `.env` and fill in your keys. `.env` is git-ignored.

# Picovoice AccessKey (optional). Get a free one at https://console.picovoice.ai
# Delete this line OR replace the placeholder — never leave the example text,
# or Picovoice init will fail with "Failed to parse AccessKey".
PICOVOICE_ACCESS_KEY=your-picovoice-access-key-here

# ElevenLabs API key (optional). Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Vosk model directory (optional). Download from https://alphacephei.com/vosk/models
# e.g. unzip vosk-model-small-en-us-0.15 and point here — powers CREATE-TKS-style
# offline “Partial:” hints when Cobra VAD is unavailable.
# VOSK_MODEL_PATH=/path/to/vosk-model-small-en-us-0.15
